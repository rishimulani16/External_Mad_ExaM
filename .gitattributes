# =============================================================================
# .gitattributes — Smart Appointment Queue App
# Enforces consistent LF line endings for all text files.
# This silences the "LF will be replaced by CRLF" Git warning on Windows.
# =============================================================================

# ---------------------------------------------------------------------------
# Default: auto-detect text files and normalise to LF in the repo.
# On checkout, Git converts to the OS line ending (CRLF on Windows).
# ---------------------------------------------------------------------------
* text=auto eol=lf

# ---------------------------------------------------------------------------
# Dart / Flutter source files — always LF
# ---------------------------------------------------------------------------
*.dart      text eol=lf
*.yaml      text eol=lf
*.yml       text eol=lf
*.json      text eol=lf
*.md        text eol=lf
*.txt       text eol=lf
*.gradle    text eol=lf
*.kts       text eol=lf
*.xml       text eol=lf
*.html      text eol=lf
*.css       text eol=lf
*.js        text eol=lf
*.ts        text eol=lf

# ---------------------------------------------------------------------------
# Git / CI config files — always LF
# ---------------------------------------------------------------------------
.gitignore      text eol=lf
.gitattributes  text eol=lf
Makefile        text eol=lf

# ---------------------------------------------------------------------------
# Shell scripts — always LF (they break with CRLF on Unix runners)
# ---------------------------------------------------------------------------
*.sh        text eol=lf
*.bash      text eol=lf

# ---------------------------------------------------------------------------
# Windows-specific scripts — keep CRLF
# ---------------------------------------------------------------------------
*.bat       text eol=crlf
*.cmd       text eol=crlf
*.ps1       text eol=crlf

# ---------------------------------------------------------------------------
# Binary files — no line-ending conversion
# ---------------------------------------------------------------------------
*.png       binary
*.jpg       binary
*.jpeg      binary
*.gif       binary
*.ico       binary
*.webp      binary
*.ttf       binary
*.otf       binary
*.woff      binary
*.woff2     binary
*.eot       binary
*.pdf       binary
*.zip       binary
*.tar       binary
*.gz        binary
*.jar       binary
*.aab       binary
*.apk       binary
*.ipa       binary
*.keystore  binary
*.jks       binary
